# https://ghostty.org/docs/config/reference
font-family = JetBrainsMonoNL Nerd Font
font-family = Osaka
# Hangul → D2Coding (monospace Korean, font-d2coding cask); Latin/JP unchanged
font-codepoint-map = U+1100-U+11FF,U+3130-U+318F,U+A960-U+A97F,U+AC00-U+D7A3,U+D7B0-U+D7FF=D2Coding
font-size = 13
confirm-close-surface = false
maximize = true
window-inherit-working-directory = false
split-inherit-working-directory = false

# Let zsh precmd control tab title, not shell integration
shell-integration-features = cursor,sudo,no-title

# Shift+Enter for Claude Code inside tmux (Ghostty native support skips /terminal-setup)
keybind = shift+enter=text:\x1b\r

