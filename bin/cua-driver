#!/usr/bin/env bash
# Wrapper around cua-driver: blocks GUI automation of sensitive apps.
#
# cua-driver can drive any app on the host (click, type, screenshot,
# read AX trees). This wrapper refuses app-targeted tool calls aimed at
# the bundle ids below (logged-in browser sessions, password manager).
# Management subcommands and target-free reads pass through; calls whose
# target app cannot be determined are refused, as is `mcp` mode (the MCP
# server would bypass per-call checks).
#
# Extend the denylist by editing DENIED_BUNDLE_IDS below.
# Bypass intentionally: invoke the real binary directly, e.g.
#   /Applications/CuaDriver.app/Contents/MacOS/cua-driver ...

set -euo pipefail

REAL=/Applications/CuaDriver.app/Contents/MacOS/cua-driver

DENIED_BUNDLE_IDS=(
    com.google.Chrome
    com.1password.1password
)

denied_bundle_id() {
    local id
    for id in "${DENIED_BUNDLE_IDS[@]}"; do
        [ "$1" = "$id" ] && return 0
    done
    return 1
}

reject() {
    cat >&2 <<EOF
cua-driver wrapper: refused $1

These apps are off-limits to cua-driver: ${DENIED_BUNDLE_IDS[*]}
They hold logged-in sessions and secrets. If this was intentional, ask
the user to adjust the denylist in ~/.dotfiles/bin/cua-driver.
EOF
    exit 1
}

[ $# -ge 1 ] || exec "$REAL"

cmd="$1"
json="${2:-}"

case "$cmd" in
    # Management subcommands and target-free reads: pass through.
    serve|stop|status|list-tools|describe|recording|set_recording|\
    list_apps|check_permissions|get_config|set_config|\
    set_agent_cursor_enabled|set_agent_cursor_motion|\
    help|-h|--help|version|--version)
        exec "$REAL" "$@"
        ;;
    mcp)
        reject "'mcp' mode (the MCP server bypasses the per-call app denylist)"
        ;;
esac

# Everything else is an app-targeted tool call; establish the target app.
bundle_id="$(printf '%s' "$json" | jq -r '.bundle_id // empty' 2>/dev/null || true)"
name="$(printf '%s' "$json" | jq -r '.name // empty' 2>/dev/null || true)"
pid="$(printf '%s' "$json" | jq -r '.pid // empty' 2>/dev/null || true)"

if [ -z "$bundle_id" ] && [ -n "$name" ]; then
    bundle_id="$(osascript -e "id of app \"$name\"" 2>/dev/null || true)"
fi
if [ -z "$bundle_id" ] && [ -n "$pid" ]; then
    bundle_id="$(lsappinfo info -only bundleid "$pid" 2>/dev/null \
        | sed -n 's/.*"CFBundleIdentifier"="\([^"]*\)".*/\1/p' || true)"
fi

if [ -z "$bundle_id" ]; then
    reject "'$cmd' (could not determine the target app from its arguments)"
fi
if denied_bundle_id "$bundle_id"; then
    reject "'$cmd' targeting '$bundle_id'"
fi

exec "$REAL" "$@"
