#!/usr/bin/env bash
# Wrapper around agent-browser: rejects real Chrome profiles, and mutes
# Chrome audio in headless mode.
#
# A real Chrome profile (~/Library/Application Support/Google/Chrome/<name>)
# carries Gmail sessions, crypto wallets, and every logged-in site. Letting
# an agent drive a browser there is unsafe. This wrapper inspects --profile
# values regardless of position and refuses dangerous ones.
#
# Allowed: project-local paths (e.g. './.agent-browser', '~/.myapp').
# Blocked: 'Default', 'Profile <N>', any path under .../Google/Chrome/.
#
# Bypass intentionally: invoke the real binary directly, e.g.
#   /opt/homebrew/bin/agent-browser --profile Default open ...

set -euo pipefail

REAL=/opt/homebrew/bin/agent-browser

is_dangerous_profile() {
    case "$1" in
        Default) return 0 ;;
        "Profile "[0-9]*) return 0 ;;
        *Google/Chrome/*) return 0 ;;
    esac
    return 1
}

reject() {
    cat >&2 <<EOF
agent-browser wrapper: refused --profile '$1'

This points at a real Chrome profile (Gmail, wallets, logged-in sites).
Use a project-local profile dir instead, e.g. './.agent-browser', or run
'/agent-browser-init' to scaffold one.
EOF
    exit 1
}

if [ -n "${AGENT_BROWSER_PROFILE:-}" ] && is_dangerous_profile "$AGENT_BROWSER_PROFILE"; then
    reject "$AGENT_BROWSER_PROFILE"
fi

# Detect headed mode. Seed from the env, then let CLI flags override it.
headed=0
case "${AGENT_BROWSER_HEADED:-}" in
    true|1|TRUE|True) headed=1 ;;
esac

i=1
while [ $i -le $# ]; do
    arg="${!i}"
    case "$arg" in
        --profile)
            j=$((i + 1))
            if [ $j -le $# ]; then
                val="${!j}"
                if is_dangerous_profile "$val"; then
                    reject "$val"
                fi
            fi
            ;;
        --profile=*)
            val="${arg#--profile=}"
            if is_dangerous_profile "$val"; then
                reject "$val"
            fi
            ;;
        --headed)
            j=$((i + 1))
            if [ $j -le $# ]; then
                case "${!j}" in
                    false|0|FALSE|False) headed=0 ;;
                    *) headed=1 ;;
                esac
            else
                headed=1
            fi
            ;;
        --headed=*)
            case "${arg#--headed=}" in
                false|0|FALSE|False) headed=0 ;;
                *) headed=1 ;;
            esac
            ;;
    esac
    i=$((i + 1))
done

# Mute Chrome audio in headless mode. The new headless mode (--headless=new)
# routes page audio to the system; --mute-audio silences it. Headed sessions
# keep sound so a watching human hears playback. Prepend so any caller-set
# AGENT_BROWSER_ARGS is preserved. A CLI --args flag overrides the env and
# would drop the mute, but that is rare in practice.
if [ "$headed" -eq 0 ]; then
    export AGENT_BROWSER_ARGS="--mute-audio${AGENT_BROWSER_ARGS:+,$AGENT_BROWSER_ARGS}"
fi

exec "$REAL" "$@"
