{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_TELEMETRY": "1",
    "GOG_JSON": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh repo view *)",
      "Bash(gh repo clone *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh search *)",
      "Bash(gh browse *)",
      "Bash(gh status *)",
      "Bash(brew *)",
      "Bash(mas list *)",
      "Bash(mas search *)",
      "Bash(mas install *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(jq *)",
      "Bash(glow *)",
      "Bash(pgrep *)",
      "Bash(gog gmail search *)",
      "Bash(gog gmail messages *)",
      "Bash(gog gmail get *)",
      "Bash(gog gmail attachment *)",
      "Bash(gog gmail url *)",
      "Bash(gog gmail history *)",
      "Bash(gog gmail thread *)",
      "Bash(gog gmail list *)",
      "Bash(gog gmail labels *)",
      "Bash(gog calendar list *)",
      "Bash(gog calendar calendars *)",
      "Bash(gog calendar acl *)",
      "Bash(gog calendar events *)",
      "Bash(gog calendar event *)",
      "Bash(gog calendar search *)",
      "Bash(gog calendar freebusy *)",
      "Bash(gog calendar colors *)",
      "Bash(gog calendar conflicts *)",
      "Bash(gog calendar time *)",
      "Bash(gog auth status *)",
      "Bash(gog auth list *)",
      "Bash(gog auth services *)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(git -C:*)",
      "Bash(git --no-pager:*)",
      "Bash(git commit --amend:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "swift-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  }
}
