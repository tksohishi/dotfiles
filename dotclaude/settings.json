{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(brew *)",
      "Bash(mas list *)",
      "Bash(mas search *)",
      "Bash(mas install *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(jq *)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(git -C:*)",
      "Bash(git --no-pager:*)",
      "Bash(git commit --amend:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "swift-lsp@claude-plugins-official": true
  }
}
