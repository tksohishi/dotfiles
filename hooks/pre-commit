#!/bin/bash
# Pre-commit hook: warn if staged changes in public agent config dirs
# contain strings that look like personal/private information.

SENSITIVE_DIRS="dotagents/ dotclaude/ dotcodex/"

staged_files=""
for dir in $SENSITIVE_DIRS; do
    files=$(git diff --cached --name-only --diff-filter=ACM -- "$dir" 2>/dev/null || true)
    staged_files="$staged_files $files"
done
staged_files=$(echo "$staged_files" | xargs)

[ -z "$staged_files" ] && exit 0

# Simple fixed-string checks (no regex issues)
BLOCKED_STRINGS=(
    "sk-ant-"
    "sk-proj-"
    "ghp_"
    "gho_"
    "ghs_"
    "Bearer "
    "AIza"
    "xoxb-"
    "xoxp-"
    "allowed_domains"
    "blocked_domains"
)

diff_content=$(git diff --cached -U0 -- $staged_files | grep '^+' | grep -v '^+++')

found=0
for str in "${BLOCKED_STRINGS[@]}"; do
    matches=$(echo "$diff_content" | grep -F "$str" || true)
    if [ -n "$matches" ]; then
        if [ "$found" -eq 0 ]; then
            echo "WARNING: Possible personal/private info in staged changes:"
            echo ""
        fi
        echo "  matched: $str"
        found=1
    fi
done

if [ "$found" -ne 0 ]; then
    echo ""
    echo "Review the diff carefully. Use .local/.override files for private settings."
    echo "To proceed anyway: git commit --no-verify"
    exit 1
fi
